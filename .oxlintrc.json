{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn"
  },
  "rules": {
    // 数系。リファクタリング過程では許容。
    "max-lines-per-function": ["allow"],
    "max-lines": ["allow"],
    "no-inline-comments": ["allow"],
    "max-depth": ["allow"],
    "max-classes-per-file": ["allow"],

    "no-negated-condition": "allow", // 二重否定。いつか直すでいいと思う。
    "no-shadow": "allow",

    "no-unused-vars": "allow", // これもリファクタリング過程のため許容。
    "no-async-endpoint-handlers": "allow", // honoなのでいいでしょう

    "no-unsafe-type-assertion": "allow",
    "no-unsafe-argument": "allow",
    "no-unsafe-assignment": "allow",
    "no-unsafe-call": "allow",
    "no-unsafe-member-access": "allow",
    "strict-boolean-expressions": "allow",
  },
  "env": {
    "builtin": true,
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    ".wrangler/**",
    "node_modules/**",
    "*.test.ts" // TODO: 後回しする
  ],
}
