{
  "name": "matrix-worker",
  "version": "0.1.0",
  "description": "Matrix homeserver running on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute tuwunel-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute tuwunel-db --local --file=./migrations/schema.sql",
    "spec:extract:markdown": "bun run scripts/spec/extract-matrix-spec-units.mjs",
    "spec:extract:openapi": "bun run scripts/spec/extract-openapi-units.mjs",
    "spec:extract": "bun run spec:extract:markdown && bun run spec:extract:openapi",
    "spec:coverage:markdown": "bun run scripts/spec/check-matrix-spec-coverage.mjs",
    "spec:coverage:openapi": "bun run scripts/spec/check-openapi-coverage.mjs",
    "spec:coverage:complement": "bun run scripts/spec/check-complement-coverage.mjs",
    "spec:coverage": "bun run spec:coverage:markdown && bun run spec:coverage:openapi && bun run spec:coverage:complement",
    "complement:setup": "bun run testing/complement/setup.ts",
    "complement:index": "bun run testing/complement/index-tests.mjs",
    "complement:build": "bun run testing/complement/run.ts --build-only",
    "complement:startup:preflight": "bun run testing/complement/startup-preflight.ts",
    "complement:run": "bun run testing/complement/run.ts",
    "complement:run:debug": "bun run testing/complement/run.ts --startup-debug",
    "complement:run:fast": "NO_BUILD=1 bun run testing/complement/run.ts",
    "complement:analyze": "bun run testing/complement/analyze.ts",
    "test": "vitest",
    "check": "tsc --noEmit",
    "check:strict-core": "bun run scripts/typecheck-strict-core.mjs",
    "check:no-explicit-any": "bun run scripts/check-no-explicit-any.mjs",
    "check:no-direct-effect-run": "bun run scripts/check-effect-runtime-boundary.mjs",
    "lint": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix",
    "lint:fix-dangerous": "oxlint src --fix --fix-suggestions --fix-dangerously",
    "lint:type": "oxlint src --type-aware --type-check -f stylish --fix --fix-suggestions --fix-dangerously",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "effect": "^3.21.0",
    "hono": "^4.6.0",
    "kysely": "^0.28.15",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "knip": "^6.3.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  },
  "packageManager": "bun"
}
